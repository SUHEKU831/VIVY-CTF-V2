<%- include('../layout/header') %>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="fas fa-user-circle"></i>
        </div>
        <div class="profile-info">
            <h1><%= user.username %></h1>
            <p class="profile-email"><i class="fas fa-envelope"></i> <%= user.email %></p>
            <p class="profile-joined"><i class="fas fa-calendar"></i> Joined <%= new Date(user.created_at).toLocaleDateString() %></p>
            
            <% if (team) { %>
                <p class="profile-team">
                    <i class="fas fa-users"></i> Team: 
                    <a href="/teams/<%= team.id %>"><%= team.name %></a>
                </p>
            <% } %>
            
            <span class="profile-role badge <%= user.role === 'admin' ? 'badge-error' : 'badge-success' %>">
                <i class="fas <%= user.role === 'admin' ? 'fa-crown' : 'fa-user' %>"></i>
                <%= user.role %>
            </span>
        </div>
    </div>
    
    <div class="profile-stats">
        <h2><i class="fas fa-chart-bar"></i> Statistics</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-flag"></i>
                <span class="stat-value"><%= stats.total_solves || 0 %></span>
                <span class="stat-label">Solves</span>
            </div>
            <div class="stat-card">
                <i class="fas fa-star"></i>
                <span class="stat-value"><%= stats.total_points || 0 %></span>
                <span class="stat-label">Points</span>
            </div>
            <div class="stat-card">
                <i class="fas fa-layer-group"></i>
                <span class="stat-value"><%= stats.categories_conquered || 0 %></span>
                <span class="stat-label">Categories</span>
            </div>
            <div class="stat-card">
                <i class="fas fa-clock"></i>
                <span class="stat-value"><%= stats.challenges_solved || 0 %></span>
                <span class="stat-label">Challenges</span>
            </div>
        </div>
    </div>
    
    <div class="profile-sections">
        <div class="profile-section">
            <h2><i class="fas fa-cog"></i> Account Settings</h2>
            
            <form method="POST" action="/profile/update" class="settings-form">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" value="<%= user.email %>" required>
                </div>
                
                <div class="form-group">
                    <label for="current_password">Current Password</label>
                    <input type="password" id="current_password" name="current_password" 
                           placeholder="Enter current password to change">
                </div>
                
                <div class="form-group">
                    <label for="new_password">New Password</label>
                    <input type="password" id="new_password" name="new_password" 
                           placeholder="Leave blank to keep current">
                </div>
                
                <div class="form-group">
                    <label for="theme">Theme Preference</label>
                    <select name="theme" id="theme" onchange="changeTheme(this.value)">
                        <option value="dark" <%= user.theme_preference === 'dark' ? 'selected' : '' %>>Dark</option>
                        <option value="hacker" <%= user.theme_preference === 'hacker' ? 'selected' : '' %>>Hacker</option>
                        <option value="neon" <%= user.theme_preference === 'neon' ? 'selected' : '' %>>Neon</option>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Update Profile
                </button>
            </form>
        </div>
        
        <div class="profile-section">
            <h2><i class="fas fa-trophy"></i> Recent Solves</h2>
            
            <% if (solves && solves.length > 0) { %>
                <div class="solves-list">
                    <% solves.slice(0, 10).forEach(solve => { %>
                        <div class="solve-item">
                            <i class="fas fa-flag-checkered"></i>
                            <div class="solve-info">
                                <span class="challenge-name"><%= solve.title %></span>
                                <span class="challenge-category"><%= solve.category %></span>
                                <span class="challenge-points">+<%= solve.points %></span>
                            </div>
                            <span class="solve-time"><%= new Date(solve.solved_at).toLocaleString() %></span>
                        </div>
                    <% }) %>
                </div>
                
                <% if (solves.length > 10) { %>
                    <a href="/profile/solves" class="view-all">View all solves →</a>
                <% } %>
            <% } else { %>
                <p class="no-data">No solves yet. <a href="/challenges">Start solving!</a></p>
            <% } %>
        </div>
        
        <div class="profile-section">
            <h2><i class="fas fa-history"></i> Recent Activity</h2>
            
            <% if (recentActivity && recentActivity.length > 0) { %>
                <div class="activity-list">
                    <% recentActivity.forEach(activity => { %>
                        <div class="activity-item">
                            <i class="fas <%= activity.type === 'solve' ? 'fa-flag' : 'fa-users' %>"></i>
                            <div class="activity-info">
                                <span class="activity-desc">
                                    <% if (activity.type === 'solve') { %>
                                        Solved <strong><%= activity.challenge_name %></strong> (+<%= activity.points %>)
                                    <% } else { %>
                                        Joined team <strong><%= activity.challenge_name %></strong>
                                    <% } %>
                                </span>
                                <span class="activity-time"><%= new Date(activity.timestamp).toLocaleString() %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="no-data">No recent activity</p>
            <% } %>
        </div>
    </div>
</div>

<style>
.profile-container {
    max-width: 1200px;
    margin: 0 auto;
}

.profile-header {
    display: flex;
    gap: 2rem;
    align-items: center;
    background-color: var(--card-bg);
    border-radius: 8px;
    padding: 2rem;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
}

.profile-avatar i {
    font-size: 5rem;
    color: var(--accent-primary);
}

.profile-info h1 {
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
}

.profile-info p {
    margin: 0.25rem 0;
    color: var(--text-secondary);
}

.profile-info i {
    width: 1.5rem;
    color: var(--accent-primary);
}

.profile-info a {
    color: var(--accent-primary);
    text-decoration: none;
}

.profile-info a:hover {
    text-decoration: underline;
}

.profile-role {
    display: inline-block;
    margin-top: 0.5rem;
}

.profile-stats {
    background-color: var(--card-bg);
    border-radius: 8px;
    padding: 2rem;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
}

.profile-stats h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--accent-primary);
}

.profile-stats h2 i {
    margin-right: 0.5rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
}

.stat-card {
    text-align: center;
    padding: 1.5rem;
    background-color: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent-primary);
}

.stat-card i {
    font-size: 2rem;
    color: var(--accent-primary);
    margin-bottom: 0.5rem;
}

.stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--text-primary);
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.profile-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
}

.profile-section {
    background-color: var(--card-bg);
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid var(--border);
}

.profile-section h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--accent-primary);
    font-size: 1.3rem;
}

.profile-section h2 i {
    margin-right: 0.5rem;
}

.settings-form .form-group {
    margin-bottom: 1.5rem;
}

.settings-form label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
}

.settings-form input,
.settings-form select {
    width: 100%;
    padding: 0.8rem;
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: 4px;
    color: var(--text-primary);
    font-size: 1rem;
}

.settings-form input:focus,
.settings-form select:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 2px rgba(114, 137, 218, 0.3);
}

.solves-list,
.activity-list {
    max-height: 300px;
    overflow-y: auto;
}

.solve-item,
.activity-item {
    display: flex;
    align-items: center;
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
}

.solve-item:hover,
.activity-item:hover {
    background-color: var(--bg-secondary);
}

.solve-item i,
.activity-item i {
    width: 2rem;
    color: var(--accent-primary);
    font-size: 1.1rem;
}

.solve-info,
.activity-info {
    flex: 1;
}

.challenge-name,
.activity-desc {
    display: block;
    color: var(--text-primary);
    font-weight: 500;
}

.challenge-category {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.challenge-points {
    color: var(--success);
    font-weight: bold;
    margin-left: 0.5rem;
}

.solve-time,
.activity-time {
    font-size: 0.85rem;
    color: var(--text-secondary);
    white-space: nowrap;
}

.view-all {
    display: block;
    text-align: center;
    margin-top: 1rem;
    color: var(--accent-primary);
    text-decoration: none;
}

.view-all:hover {
    text-decoration: underline;
}

.no-data {
    text-align: center;
    color: var(--text-secondary);
    padding: 2rem;
}

.no-data a {
    color: var(--accent-primary);
    text-decoration: none;
}

.no-data a:hover {
    text-decoration: underline;
}

@media (max-width: 768px) {
    .profile-header {
        flex-direction: column;
        text-align: center;
    }
    
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .profile-sections {
        grid-template-columns: 1fr;
    }
    
    .solve-item,
    .activity-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
    }
    
    .solve-time,
    .activity-time {
        margin-left: 2rem;
    }
}
</style>

<script>
function changeTheme(theme) {
    fetch('/change-theme', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `theme=${theme}`
    }).then(() => {
        location.reload();
    });
}

// Preview theme sebelum apply (opsional)
document.getElementById('theme').addEventListener('change', function(e) {
    const theme = e.target.value;
    // Optional: Preview theme without reload
    document.body.className = `theme-${theme}`;
});
</script>

<%- include('../layout/footer') %>