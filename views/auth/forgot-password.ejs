<%- include('../layout/header') %>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <i class="fas fa-key icon-large"></i>
            <h2>Forgot Password?</h2>
        </div>
        
        <p class="info-text">
            <i class="fas fa-info-circle"></i>
            Enter your email address and we'll send you a link to reset your password.
        </p>
        
        <form method="POST" action="/forgot-password" class="auth-form" id="forgotForm">
            <div class="form-group">
                <label for="email">
                    <i class="fas fa-envelope"></i> Email Address
                </label>
                <div class="input-wrapper">
                    <input type="email" 
                           id="email" 
                           name="email" 
                           required 
                           placeholder="your@email.com"
                           autocomplete="email"
                           class="form-control">
                    <i class="fas fa-check-circle valid-icon" style="display: none;"></i>
                    <i class="fas fa-exclamation-circle invalid-icon" style="display: none;"></i>
                </div>
                <div class="input-feedback" id="emailFeedback"></div>
            </div>
            
            <div class="captcha-container">
                <div class="g-recaptcha" data-sitekey="your-recaptcha-site-key"></div>
                <small class="form-text">This helps prevent automated requests</small>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block" id="submitBtn">
                <span class="btn-text"><i class="fas fa-paper-plane"></i> Send Reset Link</span>
                <span class="btn-loading" style="display: none;">
                    <i class="fas fa-circle-notch fa-spin"></i> Sending...
                </span>
            </button>
        </form>
        
        <div class="auth-links">
            <p><a href="/login"><i class="fas fa-arrow-left"></i> Back to Login</a></p>
            <p>Don't have an account? <a href="/register">Sign up</a></p>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div id="successModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <i class="fas fa-check-circle modal-icon success"></i>
            <h3>Check Your Email</h3>
        </div>
        <div class="modal-body">
            <p>If an account exists for <strong id="sentEmail"></strong>, you will receive a password reset link shortly.</p>
            <div class="email-tips">
                <h4><i class="fas fa-lightbulb"></i> Quick Tips:</h4>
                <ul>
                    <li><i class="fas fa-clock"></i> The link expires in 1 hour</li>
                    <li><i class="fas fa-spam"></i> Check your spam/junk folder</li>
                    <li><i class="fas fa-envelope"></i> Add noreply@vivy.ctf to your contacts</li>
                </ul>
            </div>
        </div>
        <div class="modal-footer">
            <a href="/login" class="btn btn-primary">Go to Login</a>
            <button class="btn btn-secondary" onclick="closeModal()">Close</button>
        </div>
    </div>
</div>

<style>
.auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 200px);
    padding: 2rem 1rem;
}

.auth-card {
    background-color: var(--card-bg);
    border-radius: 12px;
    padding: 2.5rem;
    width: 100%;
    max-width: 450px;
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    animation: slideUp 0.5s ease;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.auth-header {
    text-align: center;
    margin-bottom: 2rem;
}

.icon-large {
    font-size: 3.5rem;
    color: var(--accent-primary);
    margin-bottom: 1rem;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% {
        transform: scale(1);
        opacity: 1;
    }
    50% {
        transform: scale(1.05);
        opacity: 0.8;
    }
}

.auth-card h2 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1.8rem;
}

.info-text {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    padding: 1rem;
    background-color: var(--bg-secondary);
    border-radius: 8px;
    border-left: 4px solid var(--accent-primary);
    font-size: 0.95rem;
}

.info-text i {
    color: var(--accent-primary);
    margin-right: 0.5rem;
}

.auth-form .form-group {
    margin-bottom: 1.8rem;
}

.auth-form label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
}

.auth-form label i {
    margin-right: 0.5rem;
    color: var(--accent-primary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.auth-form input {
    width: 100%;
    padding: 0.9rem 1rem;
    background-color: var(--input-bg);
    border: 2px solid var(--input-border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.3s ease;
}

.auth-form input:hover {
    border-color: var(--accent-secondary);
}

.auth-form input:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(114, 137, 218, 0.2);
}

.auth-form input.valid {
    border-color: var(--success);
    padding-right: 2.5rem;
}

.auth-form input.invalid {
    border-color: var(--error);
    padding-right: 2.5rem;
}

.input-wrapper .valid-icon {
    position: absolute;
    right: 1rem;
    color: var(--success);
    font-size: 1.2rem;
}

.input-wrapper .invalid-icon {
    position: absolute;
    right: 1rem;
    color: var(--error);
    font-size: 1.2rem;
}

.input-feedback {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    min-height: 20px;
}

.input-feedback.valid {
    color: var(--success);
}

.input-feedback.invalid {
    color: var(--error);
}

.captcha-container {
    margin-bottom: 1.5rem;
    text-align: center;
}

.g-recaptcha {
    display: inline-block;
    margin-bottom: 0.5rem;
}

.form-text {
    display: block;
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.btn-block {
    width: 100%;
    padding: 1rem;
    font-size: 1.1rem;
    margin-top: 1rem;
    position: relative;
    overflow: hidden;
}

.btn-block .btn-loading {
    display: none;
}

.btn-block.loading .btn-text {
    display: none;
}

.btn-block.loading .btn-loading {
    display: inline-block;
}

.auth-links {
    text-align: center;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
}

.auth-links p {
    margin: 0.5rem 0;
    color: var(--text-secondary);
}

.auth-links a {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
}

.auth-links a:hover {
    color: var(--accent-secondary);
    text-decoration: underline;
}

.auth-links i {
    margin-right: 0.3rem;
    font-size: 0.9rem;
}

/* Modal Styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.modal-content {
    background-color: var(--card-bg);
    border-radius: 12px;
    max-width: 400px;
    width: 90%;
    border: 1px solid var(--border);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
    from {
        transform: translateY(-30px);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.modal-header {
    padding: 1.5rem;
    text-align: center;
    border-bottom: 1px solid var(--border);
}

.modal-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.modal-icon.success {
    color: var(--success);
}

.modal-header h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1.5rem;
}

.modal-body {
    padding: 1.5rem;
}

.modal-body p {
    margin: 0 0 1rem 0;
    color: var(--text-secondary);
    line-height: 1.6;
}

.modal-body strong {
    color: var(--accent-primary);
}

.email-tips {
    background-color: var(--bg-secondary);
    border-radius: 8px;
    padding: 1rem;
    margin-top: 1rem;
}

.email-tips h4 {
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    font-size: 1rem;
}

.email-tips h4 i {
    color: var(--warning);
    margin-right: 0.3rem;
}

.email-tips ul {
    margin: 0;
    padding-left: 1.5rem;
}

.email-tips li {
    margin: 0.5rem 0;
    color: var(--text-secondary);
    list-style-type: none;
    position: relative;
}

.email-tips li i {
    position: absolute;
    left: -1.5rem;
    top: 0.2rem;
    color: var(--accent-primary);
    font-size: 0.9rem;
}

.modal-footer {
    padding: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 1rem;
    justify-content: center;
}

.modal-footer .btn {
    min-width: 120px;
}

/* Resend link option */
.resend-option {
    text-align: center;
    margin-top: 1rem;
    padding: 1rem;
    background-color: var(--bg-secondary);
    border-radius: 8px;
}

.resend-option p {
    margin: 0 0 0.5rem 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.resend-link {
    color: var(--accent-primary);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
}

.resend-link:hover {
    text-decoration: underline;
}

.resend-link.disabled {
    color: var(--text-secondary);
    cursor: not-allowed;
    pointer-events: none;
    opacity: 0.5;
}

/* Responsive */
@media (max-width: 768px) {
    .auth-card {
        padding: 1.5rem;
    }
    
    .icon-large {
        font-size: 3rem;
    }
    
    .auth-card h2 {
        font-size: 1.5rem;
    }
    
    .g-recaptcha {
        transform: scale(0.85);
        transform-origin: center;
    }
    
    .modal-footer {
        flex-direction: column;
    }
    
    .modal-footer .btn {
        width: 100%;
    }
}

/* Dark theme adjustments */
[data-theme="dark"] .auth-card {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

/* Hacker theme adjustments */
[data-theme="hacker"] .auth-card {
    border-color: var(--accent-primary);
    box-shadow: 0 0 20px rgba(0, 255, 0, 0.2);
}

/* Neon theme adjustments */
[data-theme="neon"] .auth-card {
    border-image: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary)) 1;
    box-shadow: 0 0 30px rgba(255, 0, 255, 0.3);
}

/* Loading spinner animation */
@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.fa-spin {
    animation: spin 1s linear infinite;
}
</style>

<script>
// Email validation and feedback
document.getElementById('email').addEventListener('input', function(e) {
    const email = e.target.value;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const validIcon = document.querySelector('.valid-icon');
    const invalidIcon = document.querySelector('.invalid-icon');
    const feedback = document.getElementById('emailFeedback');
    
    if (email.length === 0) {
        // Reset styles
        e.target.classList.remove('valid', 'invalid');
        validIcon.style.display = 'none';
        invalidIcon.style.display = 'none';
        feedback.textContent = '';
        feedback.className = 'input-feedback';
        return;
    }
    
    if (emailRegex.test(email)) {
        e.target.classList.add('valid');
        e.target.classList.remove('invalid');
        validIcon.style.display = 'block';
        invalidIcon.style.display = 'none';
        feedback.textContent = '✓ Valid email format';
        feedback.className = 'input-feedback valid';
    } else {
        e.target.classList.add('invalid');
        e.target.classList.remove('valid');
        validIcon.style.display = 'none';
        invalidIcon.style.display = 'block';
        
        if (email.includes('@')) {
            feedback.textContent = '✗ Please complete the email address';
        } else {
            feedback.textContent = '✗ Email must contain @ symbol';
        }
        feedback.className = 'input-feedback invalid';
    }
});

// Form submission handling
document.getElementById('forgotForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const email = document.getElementById('email').value;
    const submitBtn = document.getElementById('submitBtn');
    const recaptchaResponse = grecaptcha ? grecaptcha.getResponse() : 'dummy';
    
    // Validate email
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        alert('Please enter a valid email address');
        return;
    }
    
    // Validate reCAPTCHA (if enabled)
    if (typeof grecaptcha !== 'undefined' && !recaptchaResponse) {
        alert('Please complete the reCAPTCHA');
        return;
    }
    
    // Show loading state
    submitBtn.classList.add('loading');
    submitBtn.disabled = true;
    
    try {
        // Send request
        const response = await fetch('/forgot-password', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                email: email,
                'g-recaptcha-response': recaptchaResponse
            })
        });
        
        const data = await response.json();
        
        // Hide loading state
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        
        if (data.success) {
            // Show success modal
            document.getElementById('sentEmail').textContent = email;
            document.getElementById('successModal').style.display = 'flex';
            
            // Clear form
            document.getElementById('email').value = '';
            document.getElementById('email').classList.remove('valid');
            document.querySelector('.valid-icon').style.display = 'none';
            
            // Reset reCAPTCHA
            if (grecaptcha) {
                grecaptcha.reset();
            }
            
            // Start resend timer
            startResendTimer();
        } else {
            alert(data.message || 'An error occurred. Please try again.');
        }
    } catch (error) {
        console.error('Error:', error);
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        alert('An error occurred. Please try again.');
    }
});

// Close modal function
function closeModal() {
    document.getElementById('successModal').style.display = 'none';
}

// Click outside modal to close
window.addEventListener('click', function(e) {
    const modal = document.getElementById('successModal');
    if (e.target === modal) {
        closeModal();
    }
});

// Resend functionality
let resendTimer;
let resendCooldown = 60; // 60 seconds

function startResendTimer() {
    const resendLink = document.getElementById('resendLink');
    if (!resendLink) return;
    
    resendLink.classList.add('disabled');
    resendLink.textContent = `Resend in ${resendCooldown}s`;
    
    resendTimer = setInterval(() => {
        resendCooldown--;
        resendLink.textContent = `Resend in ${resendCooldown}s`;
        
        if (resendCooldown <= 0) {
            clearInterval(resendTimer);
            resendLink.classList.remove('disabled');
            resendLink.textContent = 'Resend email';
            resendCooldown = 60;
        }
    }, 1000);
}

// Resend email function
async function resendEmail() {
    const email = document.getElementById('sentEmail').textContent;
    const resendLink = document.getElementById('resendLink');
    
    if (resendLink.classList.contains('disabled')) {
        return;
    }
    
    try {
        const response = await fetch('/forgot-password/resend', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ email: email })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Reset link resent successfully!');
            startResendTimer();
        } else {
            alert('Error resending email. Please try again later.');
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error resending email. Please try again later.');
    }
}

// Add keyboard support
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && document.getElementById('successModal').style.display === 'flex') {
        closeModal();
    }
});

// Add resend option to modal
document.addEventListener('DOMContentLoaded', function() {
    const modalBody = document.querySelector('#successModal .modal-body');
    if (modalBody) {
        const resendDiv = document.createElement('div');
        resendDiv.className = 'resend-option';
        resendDiv.innerHTML = `
            <p>Didn't receive the email?</p>
            <a href="#" onclick="resendEmail(); return false;" id="resendLink" class="resend-link">Resend email</a>
        `;
        modalBody.appendChild(resendDiv);
    }
});
</script>

<!-- Google reCAPTCHA -->
<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<%- include('../layout/footer') %>